{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "assets/**",
          "*.html",
          "legal/**",
          "content/**",
          "robots.txt",
          "sitemap.xml",
          "404.html"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "server.js" }
  ],
  "crons": [
    { "path": "/api/cron/outreach", "schedule": "0 9 * * *" },
    { "path": "/api/cron/reports",  "schedule": "0 6 1 * *"  }
  ]
}
